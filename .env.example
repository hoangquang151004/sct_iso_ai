# ==============================
# SCT-ISO.AI - Environment Template
# ==============================
# Chi khai bao ten bien. Khong dien gia tri that vao file nay.

# Core
APP_NAME=
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# Database
DATABASE_URL=
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Security
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7
TOTP_ENCRYPTION_KEY=

# CORS
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Logging & tracing
LOG_LEVEL=INFO
LOG_FORMAT=json
REQUEST_ID_HEADER=X-Request-ID

# Optional integrations
MONGODB_URL=
CHROMA_HOST=
CHROMA_PORT=8000
MQTT_BROKER_URL=
MQTT_BROKER_PORT=1883
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_ENABLE_MOCK_DATA=true
NEXT_PUBLIC_SENTRY_DSN=
