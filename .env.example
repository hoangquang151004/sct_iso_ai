# SCT-ISO.AI environment example (P5)
# Duplicate this file to `.env` and replace placeholders.

# App environment: dev | test | staging | prod
APP_ENV=dev

# PostgreSQL connection URL used by backend + Alembic
# Dev docker default: postgres / postgres / sct_iso_ai
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/sct_iso_ai

# JWT and auth token settings
JWT_SECRET_KEY=replace-me-with-a-strong-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=7

# Refresh cookie settings
# Must be true when APP_ENV is staging or prod
REFRESH_TOKEN_COOKIE_NAME=refresh_token
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAMESITE=lax
LOGIN_RATE_LIMIT=10/minute
REFRESH_RATE_LIMIT=30/minute

# Comma-separated list for FastAPI CORS middleware
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Bootstrap seed account settings
# Do not keep default values outside dev
AUTH_BOOTSTRAP_ORG_ID=11111111-1111-1111-1111-111111111111
AUTH_BOOTSTRAP_ADMIN_USERNAME=admin
AUTH_BOOTSTRAP_ADMIN_PASSWORD=admin12345
AUTH_BOOTSTRAP_ISO_MANAGER_USERNAME=iso_manager
AUTH_BOOTSTRAP_ISO_MANAGER_PASSWORD=isomanager12345

# Docker Compose postgres service variables
POSTGRES_DB=sct_iso_ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
